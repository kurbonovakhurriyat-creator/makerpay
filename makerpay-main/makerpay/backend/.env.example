# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
BASE_URL=https://api.makerpay.uz
FRONTEND_URL=https://makerpay.uz

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=makerpay_user
DB_PASSWORD=your_strong_db_password_here
DB_NAME=makerpay
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_very_long_random_jwt_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_very_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Security ──────────────────────────────────────────────────
# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ── Platform config ───────────────────────────────────────────
PLATFORM_FEE_PERCENT=1.5
WEBHOOK_MAX_RETRIES=5

# ── Provider URLs (update when you have real endpoints) ───────
TSPAY_BASE_URL=https://api.tspay.uz
PAYNEST_BASE_URL=https://api.paynest.uz
TULOVPAY_BASE_URL=https://api.tulovpay.uz
